# ─── Server ────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ───────────────────────────────
MONGODB_URI=mongodb://localhost:27017/jobportal

# ─── JWT ───────────────────────────────────
JWT_ACCESS_SECRET=your_super_secret_access_key_here_min_32_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_key_here_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Frontend URL (CORS) ───────────────────
FRONTEND_URL=http://localhost:5173

# ─── Nodemailer (Gmail SMTP) ───────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM="JobPortal <noreply@jobportal.com>"

# ─── File Upload ───────────────────────────
UPLOAD_DIR=uploads
MAX_PROFILE_PIC_SIZE=2097152    # 2MB in bytes
MAX_RESUME_SIZE=5242880         # 5MB in bytes
MAX_LOGO_SIZE=2097152           # 2MB in bytes

# ─── Rate Limiting ─────────────────────────
RATE_LIMIT_WINDOW_MS=900000     # 15 minutes
RATE_LIMIT_MAX=10               # Max 10 requests per window on auth routes
